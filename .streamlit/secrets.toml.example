# Supabase の Connection Pooling 用 URI（Session Pooler 推奨）
# mood-tracker-public と同じ Supabase プロジェクトの接続文字列を使えます
# （テーブル prefix で衝突回避しているので共有可能）
DATABASE_URL = "postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Claude API キー（アサーション相談のAI対話で使用）
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
